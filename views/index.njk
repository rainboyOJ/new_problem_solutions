{% extends "layout.njk" %}

{% block title %}题目列表 - {{ super() }}{% endblock %}

{% block content %}
<div class="row mb-4">
  <div class="col-md-8">
    <form class="d-flex" action="/" method="GET">
      <input class="form-control me-2" type="search" name="q" placeholder="搜索题目标题或ID" value="{{ query }}">
      <button class="btn btn-outline-primary" type="submit">搜索</button>
    </form>
  </div>
  <div class="col-md-4">
    <div class="d-flex gap-2">
      <select class="form-select" name="oj" onchange="filterByOJ(this.value)">
        <option value="">全部 OJ</option>
        {% for oj in ojs %}
        <option value="{{ oj }}" {% if oj === currentOJ %}selected{% endif %}>{{ oj }}</option>
        {% endfor %}
      </select>
      <select class="form-select" name="tag" onchange="filterByTag(this.value)">
        <option value="">全部标签</option>
        {% for tag in tags %}
        <option value="{{ tag }}" {% if tag === currentTag %}selected{% endif %}>{{ tag }}</option>
        {% endfor %}
      </select>
    </div>
  </div>
</div>

<div class="row">
  {% for problem in problems %}
  <div class="col-md-6 col-lg-4 mb-3">
    <div class="card h-100">
      <div class="card-body">
        <h5 class="card-title">
          <a href="{{ problem.url }}" class="text-decoration-none text-dark">
            {{ problem.title }}
          </a>
        </h5>
        <h6 class="card-subtitle mb-2 text-muted">
          {{ problem.oj }} - {{ problem.problem_id }}
        </h6>
        <div class="mb-2">
          {% if problem.tags %}
          {% for tag in problem.tags %}
          <span class="badge bg-secondary me-1">{{ tag }}</span>
          {% endfor %}
          {% endif %}
        </div>
        {% if problem.date %}
        <small class="text-muted">{{ problem.date }}</small>
        {% endif %}
      </div>
    </div>
  </div>
  {% endfor %}
</div>

{% if pagination %}
<nav aria-label="Page navigation">
  <ul class="pagination justify-content-center">
    {% if pagination.page > 1 %}
    <li class="page-item">
      <a class="page-link" href="?page={{ pagination.page - 1 }}{% if query %}&q={{ query }}{% endif %}{% if currentOJ %}&oj={{ currentOJ }}{% endif %}{% if currentTag %}&tag={{ currentTag }}{% endif %}">上一页</a>
    </li>
    {% endif %}
    
    {% for page in range(1, pagination.totalPages + 1) %}
    {% if page == pagination.page %}
    <li class="page-item active"><a class="page-link" href="#">{{ page }}</a></li>
    {% else %}
    <li class="page-item"><a class="page-link" href="?page={{ page }}{% if query %}&q={{ query }}{% endif %}{% if currentOJ %}&oj={{ currentOJ }}{% endif %}{% if currentTag %}&tag={{ currentTag }}{% endif %}">{{ page }}</a></li>
    {% endif %}
    {% endfor %}
    
    {% if pagination.page < pagination.totalPages %}
    <li class="page-item">
      <a class="page-link" href="?page={{ pagination.page + 1 }}{% if query %}&q={{ query }}{% endif %}{% if currentOJ %}&oj={{ currentOJ }}{% endif %}{% if currentTag %}&tag={{ currentTag }}{% endif %}">下一页</a>
    </li>
    {% endif %}
  </ul>
</nav>
{% endif %}
{% endblock %}

{% block scripts %}
<script>
function filterByOJ(oj) {
  const url = new URL(window.location);
  if (oj) {
    url.searchParams.set('oj', oj);
  } else {
    url.searchParams.delete('oj');
  }
  window.location = url;
}

function filterByTag(tag) {
  const url = new URL(window.location);
  if (tag) {
    url.searchParams.set('tag', tag);
  } else {
    url.searchParams.delete('tag');
  }
  window.location = url;
}
</script>
{% endblock %}