{% extends "layout.njk" %}

{% block title %}{{ problem.title }} - {{ super() }}{% endblock %}

{% block content %}
<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/">首页</a></li>
    <li class="breadcrumb-item"><a href="/?oj={{ problem.oj }}">{{ problem.oj }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ problem.problem_id }}</li>
  </ol>
</nav>

<div class="card mb-4">
  <div class="card-header">
    <div class="d-flex justify-content-between align-items-center">
      <h2 class="mb-0">{{ problem.title }}</h2>
      <a href="/" class="btn btn-outline-secondary btn-sm">返回列表</a>
    </div>
  </div>
  <div class="card-body">
    <div class="row mb-3">
      <div class="col-md-6">
        <p><strong>OJ:</strong> {{ problem.oj }}</p>
        <p><strong>题目 ID:</strong> {{ problem.problem_id }}</p>
      </div>
      <div class="col-md-6">
        {% if problem.tags %}
        <p><strong>标签:</strong>
          {% for tag in problem.tags %}
          <span class="badge bg-secondary me-1">{{ tag }}</span>
          {% endfor %}
        </p>
        {% endif %}
        {% if problem.date %}
        <p><strong>日期:</strong> {{ problem.date }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-body">
    {{ content | safe }}
  </div>
</div>
{% endblock %}