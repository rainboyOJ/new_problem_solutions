extends layout.pug

block title
  | #{problem.title} - 题目列表

block content
  nav(aria-label="breadcrumb")
    ol.breadcrumb
      li.breadcrumb-item
        a(href="/") 首页
      li.breadcrumb-item
        a(href=`/?oj=${problem.oj}`) #{problem.oj}
      li.breadcrumb-item.active(aria-current="page") #{problem.problem_id}

  .card.mb-4
    .card-header
      .d-flex.justify-content-between.align-items-center
        h2.mb-0 #{problem.title}
        a.btn.btn-outline-secondary.btn-sm(href="/") 返回列表
    .card-body
      .row.mb-3
        .col-md-6
          p
            strong OJ:
            |  #{problem.oj}
          p
            strong 题目 ID:
            |  #{problem.problem_id}
        .col-md-6
          if problem.tags
            p
              strong 标签:
              | 
              each tag in problem.tags
                span.badge.bg-secondary.me-1 #{tag}
          if problem.date
            p
              strong 日期:
              |  #{problem.date}

  .card
    .card-body
      .markdown-body
        != content
